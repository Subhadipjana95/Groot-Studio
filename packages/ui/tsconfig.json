{
  "extends": "@workspace/typescript-config/react-library.json",
  "compilerOptions": {
    "baseUrl": ".",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["next", "node"],
    "paths": {
      "@workspace/ui/*": ["./src/*"],
      "@/components/ui/*": ["./src/components/*"],
      "@/lib/utils": ["./src/lib/utils"],
      "@/*": ["./src/*"]
    }
  },
  "include": ["."],
  "exclude": ["node_modules", "dist"]
}
